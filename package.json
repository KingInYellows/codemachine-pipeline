{
  "name": "ai-feature-pipeline",
  "version": "0.1.0",
  "description": "Autonomous AI-powered feature development pipeline CLI",
  "author": "CodeMachine Team",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-feature": "./bin/run.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "cross-env NODE_ENV=development npx -y oclif manifest",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "pretest": "npm run build",
    "test": "npm run test:config && npm run test:http && npm run test:jest",
    "test:config": "vitest run src/core/config",
    "test:config:watch": "vitest watch src/core/config",
    "test:config:coverage": "vitest run src/core/config --coverage",
    "test:http": "vitest run tests/unit",
    "test:telemetry": "vitest run tests/unit/logger.spec.ts",
    "test:jest": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "smoke": "npm run smoke:version && npm run smoke:help && npm run smoke:init",
    "smoke:version": "./bin/run.js --version",
    "smoke:help": "./bin/run.js --help",
    "smoke:init": "./bin/run.js init --help",
    "dev": "./bin/dev.js",
    "validate:config": "node -e \"require('./dist/core/config/RepoConfig').loadRepoConfig('.ai-feature-pipeline/config.json')\"",
    "prepack": "npm run clean && npm run build",
    "postpack": "npm run clean",
    "prepare": "npm run build"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@oclif/core": "^4.0.30",
    "@oclif/plugin-help": "^6.2.18",
    "@oclif/plugin-plugins": "^5.4.15",
    "undici": "^7.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/ui": "^4.0.15",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.15"
  },
  "oclif": {
    "bin": "ai-feature",
    "dirname": "ai-feature",
    "commands": "./dist/cli/commands",
    "topicSeparator": " "
  },
  "keywords": [
    "oclif",
    "cli",
    "ai",
    "automation",
    "feature-development"
  ]
}
