{
  "name": "@kinginyellows/codemachine-pipeline",
  "version": "1.0.0",
  "description": "Autonomous AI-powered feature development pipeline CLI",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "author": "CodeMachine Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KingInYellows/codemachine-pipeline.git"
  },
  "bugs": {
    "url": "https://github.com/KingInYellows/codemachine-pipeline/issues"
  },
  "homepage": "https://github.com/KingInYellows/codemachine-pipeline#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codepipe": "./bin/run.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/tooling/oclif_manifest.js",
    "prebuild": "npm run clean",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "exports:check": "ts-unused-exports tsconfig.json",
    "deps:check": "madge --circular --extensions ts src",
    "deps:baseline": "node -e \"require('node:fs').mkdirSync('.deps', { recursive: true })\" && madge --circular --extensions ts src --json > .deps/cycles-baseline.json || true",
    "deps:check:ci": "node scripts/tooling/check_circular_deps.js",
    "docs:cli": "node scripts/tooling/generate_cli_reference.js",
    "docs:cli:check": "node scripts/tooling/generate_cli_reference.js --check",
    "docs:validate": "npm run docs:links:check && npm run docs:commands:check && npm run docs:examples:check && npm run docs:security:check",
    "docs:links:check": "npx --no-install markdown-link-check --help >/dev/null 2>&1 || { echo 'Skipping link check: markdown-link-check not installed. Run: npm install'; exit 0; }; find docs/guide docs/reference docs/playbooks docs/adr docs/templates -name '*.md' -print0 2>/dev/null | xargs -0 -n1 markdown-link-check --config .github/markdown-link-check.json && markdown-link-check README.md --config .github/markdown-link-check.json",
    "docs:commands:check": "node scripts/validate-docs-commands.js",
    "docs:examples:check": "node scripts/test-docs-examples.js",
    "docs:security:check": "bash scripts/security-scan-docs.sh",
    "security:glob-guard": "node scripts/tooling/check_glob_cli_advisory.js",
    "pretest": "cross-env OCLIF_SKIP_MANIFEST=1 npm run build",
    "test": "npm run test:config && npm run test:http && npm run test:integration && npm run test:commands",
    "test:config": "vitest run src/core/config",
    "test:config:watch": "vitest watch src/core/config",
    "test:config:coverage": "vitest run src/core/config --coverage",
    "test:http": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration/resume_flow.spec.ts tests/integration/cli_status_plan.spec.ts tests/integration/cliExecutionEngine.spec.ts tests/integration/commands_approve_resume_ratelimits.spec.ts tests/integration/commands_pr_create_reviewers_automerge.spec.ts tests/integration/commands_research_context.spec.ts",
    "test:smoke": "vitest run tests/integration/smoke_execution.spec.ts",
    "test:telemetry": "vitest run tests/unit/logger.spec.ts",
    "test:commands": "vitest run tests/unit/commands tests/unit/autoFixEngine.security.spec.ts tests/unit/persistence",
    "smoke": "npm run smoke:version && npm run smoke:help && npm run smoke:init",
    "smoke:version": "./bin/run.js --version",
    "smoke:help": "./bin/run.js --help",
    "smoke:init": "./bin/run.js init --help",
    "dev": "./bin/dev.js",
    "validate:config": "node -e \"require('./dist/core/config/RepoConfig').loadRepoConfig('.codepipe/config.json')\"",
    "prepack": "npm run clean && npm run build",
    "postpack": "npm run clean"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@oclif/core": "^4.0.30",
    "@oclif/plugin-help": "^6.2.37",
    "picomatch": "^4.0.3",
    "semver": "^7.7.4",
    "undici": "^7.21.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "codemachine": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.2",
    "@types/picomatch": "^4.0.2",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "madge": "^8.0.0",
    "markdown-link-check": "^3.13.6",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.7.2",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "glob": "^10.5.0",
    "test-exclude": "^7.0.1"
  },
  "oclif": {
    "bin": "codepipe",
    "dirname": "codepipe",
    "commands": "./dist/cli/commands",
    "topicSeparator": " "
  },
  "keywords": [
    "oclif",
    "cli",
    "ai",
    "automation",
    "feature-development"
  ]
}
