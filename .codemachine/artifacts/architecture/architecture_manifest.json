        "key": "6-0-glossary",
        "line": 234,
        "start_anchor": "<!-- anchor: 6-0-glossary -->",
        "description": "6. Glossary"
      },
      {
        "key": "6-0-1-artifact-bundle",
        "line": 238,
        "start_anchor": "<!-- anchor: 6-0-1-artifact-bundle -->",
        "description": "Artifact Bundle:** Structured export representing all inputs, outputs, telemetry, and approvals for a feature run, enabling offline review and compliance evidence."
      },
      {
        "key": "6-0-2-approval-gate",
        "line": 240,
        "start_anchor": "<!-- anchor: 6-0-2-approval-gate -->",
        "description": "Approval Gate:** Mandatory checkpoint requiring human or agent authorization before proceeding to the next pipeline stage (e.g., spec acceptance, PR creation)."
      },
      {
        "key": "6-0-3-auto-merge",
        "line": 242,
        "start_anchor": "<!-- anchor: 6-0-3-auto-merge -->",
        "description": "Auto-Merge:** GitHub capability enabling automatic merges once checks/approvals pass; toggled only when policy flags and approvals allow."
      },
      {
        "key": "6-0-4-context-budget",
        "line": 244,
        "start_anchor": "<!-- anchor: 6-0-4-context-budget -->",
        "description": "Context Budget:** Token/size limit for files provided to agents; ensures determinism and prevents prompt overload."
      },
      {
        "key": "6-0-5-executiontask",
        "line": 246,
        "start_anchor": "<!-- anchor: 6-0-5-executiontask -->",
        "description": "ExecutionTask:** Task object describing code generation, validation, PR operations, or deployment steps with dependencies and retry policies."
      },
      {
        "key": "6-0-6-http-ledger",
        "line": 248,
        "start_anchor": "<!-- anchor: 6-0-6-http-ledger -->",
        "description": "HTTP Ledger:** Persistent record of rate-limit quotas, resets, and backoff attempts per provider, guiding throttling behavior."
      },
      {
        "key": "6-0-7-linear-snapshot",
        "line": 250,
        "start_anchor": "<!-- anchor: 6-0-7-linear-snapshot -->",
        "description": "Linear Snapshot:** Cached representation of Linear issue payload stored in run directory for offline use and audit."
      },
      {
        "key": "6-0-8-observe-report",
        "line": 252,
        "start_anchor": "<!-- anchor: 6-0-8-observe-report -->",
        "description": "Observe Report:** Output of `ai-feature observe`, summarizing run health, KPIs, and anomalies for human review."
      },
      {
        "key": "6-0-9-plan-json",
        "line": 254,
        "start_anchor": "<!-- anchor: 6-0-9-plan-json -->",
        "description": "Plan.json:** Artifact describing ExecutionTasks, dependencies, and metadata powering the Execution Engine."
      },
      {
        "key": "6-0-10-prd",
        "line": 256,
        "start_anchor": "<!-- anchor: 6-0-10-prd -->",
        "description": "PRD (Product Requirements Document):** Artifact capturing problem statement, goals, non-goals, risks, and acceptance criteria before engineering work begins."
      },
      {
        "key": "6-0-11-resume-engine",
        "line": 258,
        "start_anchor": "<!-- anchor: 6-0-11-resume-engine -->",
        "description": "Resume Engine:** Orchestrator component that reads `last_step` and `last_error` to continue failed runs safely."
      },
      {
        "key": "6-0-12-run-directory",
        "line": 260,
        "start_anchor": "<!-- anchor: 6-0-12-run-directory -->",
        "description": "Run Directory:** Namespaced folder storing all artifacts for a single feature run, including contexts, specs, logs, metrics, traces, approvals, and exports."
      },
      {
        "key": "6-0-13-schema-version",
        "line": 262,
        "start_anchor": "<!-- anchor: 6-0-13-schema-version -->",
        "description": "Schema Version:** Version number stored in RepoConfig indicating configuration format; CLI enforces compatibility before running commands."
      },
      {
        "key": "6-0-14-state-machine",
        "line": 264,
        "start_anchor": "<!-- anchor: 6-0-14-state-machine -->",
        "description": "State Machine:** Finite set of statuses (`draft`, `in_progress`, `review`, `done`, `deployed`) plus transitions governing feature lifecycle."
      },
      {
        "key": "6-0-15-telemetry-hub",
        "line": 266,
        "start_anchor": "<!-- anchor: 6-0-15-telemetry-hub -->",
        "description": "Telemetry Hub:** Local collection of logs, metrics, and traces produced by each run to guarantee observability without cloud services."
      },
      {
        "key": "6-0-16-trace-map",
        "line": 268,
        "start_anchor": "<!-- anchor: 6-0-16-trace-map -->",
        "description": "Trace Map:** Document linking PRD goals to spec requirements, ExecutionTasks, git commits, and deployment evidence for auditability."
      },
      {
        "key": "6-0-17-ulid",
        "line": 270,
        "start_anchor": "<!-- anchor: 6-0-17-ulid -->",
        "description": "ULID/UUIDv7:** Timestamp-sortable identifiers used for features and tasks to simplify ordering and ensure uniqueness."
      },
      {
        "key": "6-0-18-validation-registry",
        "line": 272,
        "start_anchor": "<!-- anchor: 6-0-18-validation-registry -->",
        "description": "Validation Registry:** Configured list of commands (lint/test/build) executed before PR creation or deploy, with metadata about exit codes and retries."
      },
      {
        "key": "6-0-19-zod",
        "line": 274,
        "start_anchor": "<!-- anchor: 6-0-19-zod -->",
        "description": "Zod:** TypeScript schema validation library used to validate configs, adapter responses, and artifact structures."
      }
    ],
