{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codemachine-pipeline/schemas/repo_config.json",
  "title": "RepoConfig",
  "description": "Configuration schema for codemachine-pipeline repository settings",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "github",
    "linear",
    "runtime",
    "safety",
    "feature_flags"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for configuration migrations",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "default": "1.0.0"
    },
    "project": {
      "type": "object",
      "description": "Project-level metadata and repository information",
      "required": ["id", "repo_url"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique project identifier"
        },
        "repo_url": {
          "type": "string",
          "description": "Repository URL (GitHub HTTPS or SSH)",
          "pattern": "^(https?://|git@)"
        },
        "default_branch": {
          "type": "string",
          "description": "Default branch for PRs",
          "default": "main"
        },
        "context_paths": {
          "type": "array",
          "description": "Paths to include in context gathering",
          "items": {
            "type": "string"
          },
          "default": ["src/", "docs/", "README.md"]
        },
        "project_leads": {
          "type": "array",
          "description": "GitHub usernames of project leads",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "github": {
      "type": "object",
      "description": "GitHub integration configuration and credentials",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable GitHub integration"
        },
        "token_env_var": {
          "type": "string",
          "description": "Environment variable name for GitHub PAT",
          "default": "GITHUB_TOKEN"
        },
        "api_base_url": {
          "type": "string",
          "description": "GitHub API base URL (for Enterprise)",
          "default": "https://api.github.com"
        },
        "required_scopes": {
          "type": "array",
          "description": "Required PAT scopes",
          "items": {
            "type": "string",
            "enum": ["repo", "workflow", "read:org", "write:org"]
          },
          "default": ["repo", "workflow"]
        },
        "api_version": {
          "type": "string",
          "description": "GitHub API version (YYYY-MM-DD format)",
          "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$",
          "default": "2022-11-28"
        },
        "default_reviewers": {
          "type": "array",
          "description": "Default PR reviewers",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "branch_protection": {
          "type": "object",
          "description": "Branch protection settings awareness",
          "properties": {
            "respect_required_reviews": {
              "type": "boolean",
              "default": true
            },
            "respect_status_checks": {
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    },
    "linear": {
      "type": "object",
      "description": "Linear integration configuration",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Linear integration"
        },
        "api_key_env_var": {
          "type": "string",
          "description": "Environment variable name for Linear API key",
          "default": "LINEAR_API_KEY"
        },
        "team_id": {
          "type": "string",
          "description": "Linear team ID"
        },
        "project_id": {
          "type": "string",
          "description": "Linear project ID"
        },
        "auto_link_issues": {
          "type": "boolean",
          "description": "Automatically link Linear issues to PRs",
          "default": true
        }
      }
    },
    "runtime": {
      "type": "object",
      "description": "Runtime execution settings",
      "properties": {
        "agent_endpoint": {
          "type": "string",
          "description": "AI agent service endpoint"
        },
        "agent_endpoint_env_var": {
          "type": "string",
          "description": "Environment variable for agent endpoint",
          "default": "AGENT_ENDPOINT"
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "description": "Maximum concurrent execution tasks",
          "minimum": 1,
          "maximum": 10,
          "default": 3
        },
        "timeout_minutes": {
          "type": "integer",
          "description": "Task execution timeout in minutes",
          "minimum": 5,
          "maximum": 120,
          "default": 30
        },
        "context_token_budget": {
          "type": "integer",
          "description": "Token budget for context gathering",
          "minimum": 1000,
          "maximum": 100000,
          "default": 32000
        },
        "logs_format": {
          "type": "string",
          "description": "Log format for run artifacts",
          "enum": ["ndjson", "json", "text"],
          "default": "ndjson"
        },
        "run_directory": {
          "type": "string",
          "description": "Base directory for feature runs",
          "default": ".codepipe/runs"
        },
        "context_cost_budget_usd": {
          "type": "number",
          "description": "USD budget for context summarization",
          "default": 5
        }
      }
    },
    "safety": {
      "type": "object",
      "description": "Security and safety controls",
      "properties": {
        "redact_secrets": {
          "type": "boolean",
          "description": "Enable secret redaction in logs",
          "default": true
        },
        "require_approval_for_prd": {
          "type": "boolean",
          "description": "Require human approval for PRD",
          "default": true
        },
        "require_approval_for_plan": {
          "type": "boolean",
          "description": "Require human approval for execution plan",
          "default": true
        },
        "require_approval_for_pr": {
          "type": "boolean",
          "description": "Require human approval before creating PR",
          "default": true
        },
        "prevent_force_push": {
          "type": "boolean",
          "description": "Prevent force pushes to branches",
          "default": true
        },
        "allowed_file_patterns": {
          "type": "array",
          "description": "File patterns allowed for modification",
          "items": {
            "type": "string"
          },
          "default": ["**/*.ts", "**/*.js", "**/*.md", "**/*.json"]
        },
        "blocked_file_patterns": {
          "type": "array",
          "description": "File patterns blocked from modification",
          "items": {
            "type": "string"
          },
          "default": [".env", "**/*.key", "**/*.pem", "**/credentials.*"]
        }
      }
    },
    "feature_flags": {
      "type": "object",
      "description": "Feature flags for experimental functionality",
      "properties": {
        "enable_auto_merge": {
          "type": "boolean",
          "description": "Enable automatic PR merge after approval",
          "default": false
        },
        "enable_deployment_triggers": {
          "type": "boolean",
          "description": "Enable deployment workflow triggers",
          "default": false
        },
        "enable_linear_sync": {
          "type": "boolean",
          "description": "Enable Linear issue synchronization",
          "default": false
        },
        "enable_context_summarization": {
          "type": "boolean",
          "description": "Enable context summarization for large codebases",
          "default": true
        },
        "enable_resumability": {
          "type": "boolean",
          "description": "Enable feature resumability from checkpoints",
          "default": true
        },
        "enable_developer_preview": {
          "type": "boolean",
          "description": "Enable developer preview features",
          "default": false
        }
      }
    },
    "validation": {
      "type": "object",
      "description": "Validation command registry configuration (ADR-7 / FR-14)",
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "description": "Validation command definitions",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "command"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["lint", "test", "typecheck", "build"],
                "description": "Validation command type"
              },
              "command": {
                "type": "string",
                "minLength": 1,
                "description": "Shell command template"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory (relative or absolute)",
                "default": "."
              },
              "env": {
                "type": "object",
                "description": "Additional environment variables",
                "additionalProperties": { "type": "string" }
              },
              "required": {
                "type": "boolean",
                "description": "Whether the command blocks PR/deploy",
                "default": true
              },
              "timeout_ms": {
                "type": "integer",
                "description": "Timeout per attempt in milliseconds",
                "minimum": 1000,
                "maximum": 600000,
                "default": 120000
              },
              "max_retries": {
                "type": "integer",
                "description": "Additional retries after the first attempt",
                "minimum": 0,
                "maximum": 10,
                "default": 3
              },
              "backoff_ms": {
                "type": "integer",
                "description": "Backoff multiplier between retries in milliseconds",
                "minimum": 100,
                "maximum": 10000,
                "default": 1000
              },
              "supports_auto_fix": {
                "type": "boolean",
                "description": "Enable auto-fix loop",
                "default": false
              },
              "auto_fix_command": {
                "type": "string",
                "description": "Alternate command for auto-fix attempts"
              },
              "description": {
                "type": "string",
                "description": "Human-friendly description"
              },
              "template_context": {
                "type": "object",
                "description": "Per-command templating tokens",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        },
        "template_context": {
          "type": "object",
          "description": "Global templating tokens applied to each command",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "execution": {
      "type": "object",
      "description": "CodeMachine CLI integration and execution settings",
      "properties": {
        "codemachine_cli_path": {
          "type": "string",
          "description": "Path to the CodeMachine CLI binary",
          "default": "codemachine"
        },
        "default_engine": {
          "type": "string",
          "description": "Default execution engine",
          "enum": ["claude", "codex", "openai"],
          "default": "claude"
        },
        "workspace_dir": {
          "type": "string",
          "description": "Working directory for execution"
        },
        "spec_path": {
          "type": "string",
          "description": "Path to specification file"
        },
        "task_timeout_ms": {
          "type": "integer",
          "description": "Task timeout in milliseconds",
          "minimum": 60000,
          "maximum": 7200000,
          "default": 1800000
        },
        "max_parallel_tasks": {
          "type": "integer",
          "description": "Maximum parallel task executions",
          "minimum": 1,
          "maximum": 10,
          "default": 1
        },
        "max_log_buffer_size": {
          "type": "integer",
          "description": "Maximum log buffer size in bytes",
          "minimum": 1024,
          "maximum": 104857600,
          "default": 10485760
        },
        "env_allowlist": {
          "type": "array",
          "description": "Environment variables to pass through to tasks",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "max_retries": {
          "type": "integer",
          "description": "Maximum retry attempts per task",
          "minimum": 0,
          "maximum": 10,
          "default": 3
        },
        "retry_backoff_ms": {
          "type": "integer",
          "description": "Backoff interval between retries in milliseconds",
          "minimum": 1000,
          "default": 5000
        },
        "log_rotation_mb": {
          "type": "integer",
          "description": "Log file rotation threshold in MB",
          "minimum": 1,
          "maximum": 10240,
          "default": 100
        },
        "log_rotation_keep": {
          "type": "integer",
          "description": "Number of rotated log files to keep",
          "minimum": 1,
          "maximum": 20,
          "default": 3
        },
        "log_rotation_compress": {
          "type": "boolean",
          "description": "Compress rotated log files",
          "default": false
        }
      }
    },
    "constraints": {
      "type": "object",
      "description": "Resource constraints and limits",
      "properties": {
        "max_file_size_kb": {
          "type": "integer",
          "description": "Maximum file size for context in KB",
          "minimum": 100,
          "maximum": 10000,
          "default": 1000
        },
        "max_context_files": {
          "type": "integer",
          "description": "Maximum files to include in context",
          "minimum": 10,
          "maximum": 1000,
          "default": 100
        },
        "rate_limits": {
          "type": "object",
          "description": "API rate limit configurations",
          "properties": {
            "github_requests_per_hour": {
              "type": "integer",
              "default": 5000
            },
            "linear_requests_per_minute": {
              "type": "integer",
              "default": 60
            },
            "agent_requests_per_hour": {
              "type": "integer",
              "default": 100
            }
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "description": "Governance controls for approval workflows and accountability (ADR-5)",
      "properties": {
        "approval_workflow": {
          "type": "object",
          "description": "Gate-by-gate approval requirements",
          "properties": {
            "require_approval_for_prd": { "type": "boolean", "default": true },
            "require_approval_for_spec": { "type": "boolean", "default": true },
            "require_approval_for_plan": { "type": "boolean", "default": true },
            "require_approval_for_code": { "type": "boolean", "default": true },
            "require_approval_for_pr": { "type": "boolean", "default": true },
            "require_approval_for_deploy": { "type": "boolean", "default": true }
          }
        },
        "accountability": {
          "type": "object",
          "description": "Accountability and audit settings",
          "properties": {
            "record_approver_identity": { "type": "boolean", "default": true },
            "require_approval_reason": { "type": "boolean", "default": false },
            "audit_log_retention_days": { "type": "integer", "minimum": 1, "maximum": 3650, "default": 365 }
          }
        },
        "risk_controls": {
          "type": "object",
          "description": "Risk containment controls",
          "properties": {
            "prevent_auto_merge": { "type": "boolean", "default": true },
            "prevent_force_push": { "type": "boolean", "default": true },
            "require_branch_protection": { "type": "boolean", "default": true },
            "max_files_per_pr": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 100 },
            "max_lines_changed_per_pr": { "type": "integer", "minimum": 1, "maximum": 50000, "default": 5000 }
          }
        },
        "compliance_tags": {
          "type": "array",
          "description": "Compliance tags",
          "items": { "type": "string" },
          "default": []
        },
        "governance_notes": {
          "type": "string",
          "description": "Free-form governance documentation"
        }
      }
    },
    "config_history": {
      "type": "array",
      "description": "Migration history for schema version tracking (ADR-2)",
      "items": {
        "type": "object",
        "required": ["timestamp", "schema_version", "changed_by", "change_description"],
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "changed_by": { "type": "string" },
          "change_description": { "type": "string" },
          "migration_applied": { "type": "boolean", "default": false },
          "backup_path": { "type": "string" }
        }
      },
      "default": []
    },
    "governance_notes": {
      "type": "string",
      "description": "DEPRECATED: Use governance.governance_notes instead"
    }
  }
}
